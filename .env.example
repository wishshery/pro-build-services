# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
# The default build falls back to static project data when these are missing.
# Add these values to enable the private Supabase upload page.
#
# To use: copy this file to ".env" and fill in your values. Vite only exposes
# variables that start with VITE_ to the browser.
# ---------------------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
