# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
# The default build uses a static JSON data store and needs NO environment
# variables at all. This file is only relevant if you later upgrade the Upload
# page to a real backend (Supabase or Firebase) so uploads persist for ALL
# visitors automatically.
#
# To use: copy this file to ".env" and fill in your values. Vite only exposes
# variables that start with VITE_ to the browser.
# ---------------------------------------------------------------------------

# --- Option A: Supabase (recommended if you want a real backend) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Option B: Firebase ---
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_APP_ID=your-app-id
